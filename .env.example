# Required
DATABASE_URL=postgresql://user:password@localhost:5432/auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google/callback

# Optional
# HTTP server port. Defaults to 3000 when omitted.
PORT=3000

# Runtime environment.
# In production, cookies are marked as secure.
NODE_ENV=development

# Redis
# The current Redis client uses the default local Redis connection:
# redis://localhost:6379
#
# If you want Redis to be configurable through env, first wire REDIS_URL
# in src/infrastructure/cache/redis.ts, then uncomment this:
# REDIS_URL=redis://localhost:6379
